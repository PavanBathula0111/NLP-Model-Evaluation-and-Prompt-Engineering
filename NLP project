ce, generated)['rougeL'].fmeasure, 4)\n","\n","\n","    try:\n","        coherence = float(row['Coherence (1В–5)'])\n","        logic = float(row['Logical Consistency (1В–5)'])\n","        success = \"Y\" if coherence >= 3.5 and logic >= 3.5 else \"N\"\n","    except:\n","        success = \"N\"\n","\n","    return pd.Series([bleu, rouge_l, success])\n","\n","\n","df[['BLEU Score', 'ROUGE Score', 'Task Success Rate']] = df.apply(evaluate_row, axis=1)\n","\n","\n","output_path = \"/content/drive/MyDrive/updated_NLP.csv\"\n","df.to_csv(output_path, index=False)\n","\n","print(f\"вњ… Done! BLEU, ROUGE, and Task Success added.\\nрџ“„ Saved to: {output_path}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"_p2fDyeZIXjo","executionInfo":{"status":"ok","timestamp":1745104313764,"user_tz":240,"elapsed":4429,"user":{"displayName":"Bathula Pavan","userId":"06243183713635104593"}},"outputId":"b57518d4-3898-4606-f67d-a5d91c3e93a5"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["Requirement already satisfied: nltk in /usr/local/lib/python3.11/dist-packages (3.9.1)\n","Requirement already satisfied: rouge-score in /usr/local/lib/python3.11/dist-packages (0.1.2)\n","Requirement already satisfied: click in /usr/local/lib/python3.11/dist-packages (from nltk) (8.1.8)\n","Requirement already satisfied: joblib in /usr/local/lib/python3.11/dist-packages (from nltk) (1.4.2)\n","Requirement already satisfied: regex>=2021.8.3 in /usr/local/lib/python3.11/dist-packages (from nltk) (2024.11.6)\n","Requirement already satisfied: tqdm in /usr/local/lib/python3.11/dist-packages (from nltk) (4.67.1)\n","Requirement already satisfied: absl-py in /usr/local/lib/python3.11/dist-packages (from rouge-score) (1.4.0)\n","Requirement already satisfied: numpy in /usr/local/lib/python3.11/dist-packages (from rouge-score) (2.0.2)\n","Requirement already satisfied: six>=1.14.0 in /usr/local/lib/python3.11/dist-packages (from rouge-score) (1.17.0)\n","в